# ============================================
# MIKKAL — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub
# ============================================

# ANTHROPIC (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CLERK AUTH (get from clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/welcome
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/welcome

# SUPABASE (get from supabase.com dashboard)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# TAVILY SEARCH (get from tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# OPENAI / DALL-E (get from platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# STABILITY AI (get from platform.stability.ai)
STABILITY_API_KEY=your_stability_api_key_here

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Mikkal
NEXT_PUBLIC_APP_URL=https://mikkal.ai
ADMIN_USER_ID=your_clerk_user_id_here
