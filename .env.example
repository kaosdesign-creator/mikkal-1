# ============================================
# MIKKAL v2 — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your keys
# NEVER commit .env.local to GitHub
# ============================================

# ANTHROPIC
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# NEXTAUTH — Authentication
# Generate a secret: run this in terminal: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here_minimum_32_chars
NEXTAUTH_URL=https://mikkal.vercel.app

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# TAVILY SEARCH
TAVILY_API_KEY=your_tavily_api_key_here

# OPENAI / DALL-E
OPENAI_API_KEY=your_openai_api_key_here

# STABILITY AI
STABILITY_API_KEY=your_stability_api_key_here

# APP CONFIG
NEXT_PUBLIC_APP_NAME=Mikkal
NEXT_PUBLIC_APP_URL=https://mikkal.vercel.app
